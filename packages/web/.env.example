# Chain the dashboard talks to: 31337 = local anvil, 84532 = Base Sepolia
NEXT_PUBLIC_CHAIN_ID=31337
NEXT_PUBLIC_RPC_URL=http://127.0.0.1:8545
# AegisEscrow deployment (scripts/seed-local.mjs prints this for local dev)
NEXT_PUBLIC_ESCROW_ADDRESS=0xe7f1725E7734CE288F8367e1Bb143E90bb3F0512
# Block the escrow was deployed at — event scans start here (0 for local anvil).
# Public RPCs cap eth_getLogs at 2000 blocks, so a real start block avoids a
# from-zero scan. Base Sepolia deployment: 43984800.
NEXT_PUBLIC_START_BLOCK=0
# Pimlico bundler + verifying paymaster — enables gasless passkey flows
NEXT_PUBLIC_PIMLICO_API_KEY=
